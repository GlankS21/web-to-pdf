    if (options.expandImages) {
      console.log('🖼️ Starting image expansion...');

      await page.evaluate(async () => {
        await new Promise((resolve) => {
          let totalHeight = 0;
          const distance = 100;
          const timer = setInterval(() => {
            window.scrollBy(0, distance);
            totalHeight += distance;
            if (totalHeight >= document.body.scrollHeight) {
              clearInterval(timer);
              resolve();
            }
          }, 100);
        });
      });

      console.log('✅ Scrolled to bottom');
      await page.waitForTimeout(2000);
      await page.evaluate(() => window.scrollTo(0, 0));
      await page.waitForTimeout(1000);

      const extractedCount = await page.evaluate(() => {
        const allElements = document.querySelectorAll('*');
        const extractedImages = new Set();
        
        allElements.forEach(el => {
          const modalData = el.getAttribute('data-js-modal-open');
          if (modalData) {
            try {
              const parsed = JSON.parse(modalData);
              if (parsed.src) {
                const modalId = parsed.src.replace('#', '');
                const modal = document.getElementById(modalId);
                if (modal) {
                  modal.querySelectorAll('img').forEach(img => {
                    if (img.src) extractedImages.add(img.src);
                  });
                }
              }
            } catch (e) {}
          }

          Array.from(el.attributes).forEach(attr => {
            if (attr.name.startsWith('data-')) {
              try {
                const jsonData = JSON.parse(attr.value);
                const extractFromJson = (obj) => {
                  if (typeof obj === 'string' && obj.match(/\.(jpg|jpeg|png|webp|gif)/i)) {
                    extractedImages.add(obj);
                  } else if (typeof obj === 'object' && obj !== null) {
                    Object.values(obj).forEach(val => extractFromJson(val));
                  }
                };
                extractFromJson(jsonData);
              } catch (e) {}
            }
          });

          if (el.tagName === 'IMG' && el.src) {
            extractedImages.add(el.src);
          }
        });

        if (extractedImages.size > 0) {
          const container = document.createElement('div');
          container.style.display = 'grid';
          container.style.gridTemplateColumns = 'repeat(2, 1fr)';
          container.style.gap = '10px';
          container.style.margin = '20px 0';
          
          extractedImages.forEach(url => {
            const img = document.createElement('img');
            img.src = url;
            img.loading = 'eager';
            img.style.maxWidth = '100%';
            img.style.height = 'auto';
            container.appendChild(img);
          });
          
          document.body.appendChild(container);
        }

        document.querySelectorAll('img[loading="lazy"]').forEach(img => {
          img.loading = 'eager';
        });

        return extractedImages.size;
      });

      console.log(`✅ Extracted ${extractedCount} images`);
      await page.waitForTimeout(3000);
    }


